# MediArk 环境变量配置
# 复制此文件为 .env 并填入真实值

# 服务端口（默认 3000）
PORT=3000

# AI 生成模式：mock（离线模拟）/ live（真实调用 API）
MEDIARK_MODE=live

# ---- 文本生成（豆包大模型 Doubao）----
MEDIARK_TEXT_API_KEY=你的豆包API密钥
MEDIARK_TEXT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MEDIARK_TEXT_MODEL=你的模型endpoint-id

# ---- 图片生成（Seedream）----
MEDIARK_IMAGE_API_KEY=你的图片API密钥
MEDIARK_IMAGE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
MEDIARK_IMAGE_MODEL=bytedance-seedream-5.0-lite

# ---- 视频生成（Seedance）----
MEDIARK_VIDEO_API_KEY=你的视频API密钥
MEDIARK_VIDEO_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
MEDIARK_VIDEO_MODEL=seedance-1-5-pro-251215
